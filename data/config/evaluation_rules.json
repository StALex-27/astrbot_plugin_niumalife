{
  "_comment": "打工系统V2 - 评价规则配置",
  "_version": "1.0",
  "_description": "六维评价体系的权重和参数配置",

  "evaluation_grades": {
    "S": {
      "name": "完美",
      "min_score": 90,
      "reward_multiplier": 2.0,
      "bonus_gold_percent": 50,
      "bonus_favorability": 10,
      "description": "综合分≥90"
    },
    "A": {
      "name": "优秀",
      "min_score": 75,
      "reward_multiplier": 1.5,
      "bonus_gold_percent": 20,
      "bonus_favorability": 5,
      "description": "综合分≥75"
    },
    "B": {
      "name": "良好",
      "min_score": 60,
      "reward_multiplier": 1.2,
      "bonus_gold_percent": 0,
      "bonus_favorability": 2,
      "description": "综合分≥60"
    },
    "C": {
      "name": "合格",
      "min_score": 45,
      "reward_multiplier": 1.0,
      "bonus_gold_percent": 0,
      "bonus_favorability": 0,
      "description": "综合分≥45"
    },
    "D": {
      "name": "较差",
      "min_score": 30,
      "reward_multiplier": 0.8,
      "bonus_gold_percent": 0,
      "bonus_favorability": -5,
      "description": "综合分≥30"
    },
    "F": {
      "name": "失败",
      "min_score": 0,
      "reward_multiplier": 0.5,
      "bonus_gold_percent": 0,
      "bonus_favorability": -20,
      "fail_ban_hours": 3,
      "description": "综合分<30"
    }
  },

  "weight_config": {
    "efficiency": {
      "weight": 0.20,
      "max_score": 100,
      "description": "效率分占比20%"
    },
    "quality": {
      "weight": 0.15,
      "max_score": 100,
      "description": "质量分占比15%"
    },
    "stress": {
      "weight": 0.10,
      "base_score": 50,
      "description": "压力影响占比10%"
    },
    "mood": {
      "weight": 0.10,
      "base_score": 50,
      "description": "心情影响占比10%"
    },
    "skill_match": {
      "weight": 0.25,
      "base_score": 50,
      "description": "技能匹配占比25%"
    },
    "buff": {
      "weight": 0.20,
      "base_score": 50,
      "description": "Buff加成占比20%"
    }
  },

  "stress_rules": {
    "thresholds": [
      {"min": 0, "max": 30, "bonus": 5, "description": "适度压力有助于集中"},
      {"min": 30, "max": 50, "bonus": 0, "description": "正常压力"},
      {"min": 50, "max": 70, "bonus": -5, "description": "轻度压力"},
      {"min": 70, "max": 90, "bonus": -10, "description": "较大压力"},
      {"min": 90, "max": 100, "bonus": -20, "description": "极大压力"}
    ],
    "_stress_penalty_in_reward": {
      "_deprecated": "压力惩罚已移至评价系统，此处保留仅用于兼容",
      "enabled": false
    }
  },

  "mood_rules": {
    "thresholds": [
      {"min": 0, "max": 20, "bonus": -15, "description": "心情极差"},
      {"min": 20, "max": 40, "bonus": -5, "description": "心情较差"},
      {"min": 40, "max": 60, "bonus": 0, "description": "心情一般"},
      {"min": 60, "max": 80, "bonus": 5, "description": "心情较好"},
      {"min": 80, "max": 100, "bonus": 10, "description": "心情极佳"}
    ],
    "states": {
      "terrible": {"min": 0, "max": 20, "consume_multiplier": 1.5},
      "bad": {"min": 20, "max": 40, "consume_multiplier": 1.2},
      "normal": {"min": 40, "max": 60, "consume_multiplier": 1.0},
      "good": {"min": 60, "max": 80, "consume_multiplier": 0.85},
      "great": {"min": 80, "max": 100, "consume_multiplier": 0.7}
    }
  },

  "skill_match_rules": {
    "thresholds": [
      {"requirement_diff": -10, "bonus": -10, "description": "技能低于需求"},
      {"requirement_diff": 0, "bonus": 0, "description": "技能刚好满足"},
      {"requirement_diff": 1, "bonus": 5, "description": "技能略高于需求"},
      {"requirement_diff": 2, "bonus": 10, "description": "技能高于需求"},
      {"requirement_diff": 3, "bonus": 15, "description": "技能明显高于需求"},
      {"requirement_diff": 5, "bonus": 25, "description": "技能远超需求，上限"}
    ],
    "_calculation_method": "bonus = min(25, (player_level - required_level) * 5.0) for each required skill, then average",
    "_penalty_for_low_skill": "max(-10, (player_level - required_level) * 5.0) per skill, no lower than -10"
  },

  "buff_rules": {
    "positive_bonus_max": 30,
    "negative_penalty_min": -20,
    "buff_types": {
      "evaluation_bonus": {"description": "评价直接加成", "stackable": false},
      "reward_bonus": {"description": "奖励加成", "stackable": true},
      "income_bonus": {"description": "收入加成", "stackable": true},
      "efficiency_bonus": {"description": "效率加成", "stackable": true},
      "quality_bonus": {"description": "质量加成", "stackable": true}
    },
    "_stack_rule": "同类型Buff取最高值，不同类型Buff可叠加",
    "_debuff_handling": "Debuff单独计算后作为乘法因子（如-20% → ×0.8）"
  },

  "efficiency_calculation": {
    "_formula": "efficiency_score = min(100, (expected_time / actual_time * 100))",
    "_description": "预定时间/实际时间 = 效率分数，上限100",
    "_examples": [
      {"actual": 2, "expected": 3, "result": 150, "capped": 100, "description": "提前完成"},
      {"actual": 3, "expected": 3, "result": 100, "description": "准时完成"},
      {"actual": 6, "expected": 3, "result": 50, "description": "超时完成"}
    ]
  },

  "quality_calculation": {
    "_formula": "quality_score = max(0, min(100, (2.0 - consume_ratio) * 50))",
    "_description": "消耗比率越低质量越高，2.0为基准",
    "_consume_ratio": "actual_consume / expected_consume",
    "_examples": [
      {"actual": 50, "expected": 100, "ratio": 0.5, "result": 75, "description": "消耗低于预期"},
      {"actual": 100, "expected": 100, "ratio": 1.0, "result": 50, "description": "消耗符合预期"},
      {"actual": 200, "expected": 100, "ratio": 2.0, "result": 0, "description": "消耗远高于预期"}
    ]
  },

  "final_score_calculation": {
    "_formula": "raw_score = (efficiency * 0.20) + (quality * 0.15) + ((50 + stress) * 0.10) + ((50 + mood) * 0.10) + ((50 + skill_match) * 0.25) + ((50 + buff) * 0.20)",
    "_description": "各维度加权求和，归一化到0-100",
    "_final_transform": "final_score = max(0, min(100, raw_score))"
  },

  "reward_calculation": {
    "_formula": "最终奖励 = base_reward × 难度倍率 × (1 + Σ各类加成) × 评价倍率",
    "_difficulty_multiplier": {
      "D": 0.6,
      "C": 0.8,
      "B": 1.0,
      "A": 1.3,
      "S": 1.6,
      "S+": 2.0
    },
    "_bonus_types": [
      "equipment_bonus",
      "company_bonus",
      "stock_bonus",
      "temp_buff",
      "favorability_bonus"
    ],
    "_bonus_cap": 2.0,
    "_description": "Σ各类加成上限为200%，即(1 + 2.0) = 3.0",
    "_debuff_handling": "负面状态单独作为乘法因子，如 ×0.9"
  },

  "difficulty_config": {
    "skill_requirement": {
      "D": {"min_level": 1, "description": "入门级"},
      "C": {"min_level": 2, "description": "简单"},
      "B": {"min_level": 3, "description": "普通"},
      "A": {"min_level": 5, "description": "困难"},
      "S": {"min_level": 7, "description": "精英"},
      "S+": {"min_level": 9, "description": "传说"}
    },
    "expected_evaluation": {
      "D": "容易获得A",
      "C": "容易获得A",
      "B": "可获得A",
      "A": "需要B以上",
      "S": "需要B以上",
      "S+": "挑战级"
    },
    "consume_multiplier": {
      "D": 0.8,
      "C": 1.0,
      "B": 1.2,
      "A": 1.5,
      "S": 2.0,
      "S+": 2.5
    }
  },

  "_internal_notes": {
    "grade_determination": "按S/A/B/C/D/F顺序，第一个满足min_score的即为最终等级",
    "efficiency_capped": "效率分上限100，即使提前很多也不超过100",
    "stress_mood_range": "stress和mood的bonus范围是-20~+10和-15~+10，加上base 50后是30~70",
    "skill_range": "技能加成范围-10~+25，加上base 50后是40~75",
    "buff_range": "Buff加成范围-20~+30，加上base 50后是30~80",
    "weighted_sum_range": "考虑所有权重: 0.2*100 + 0.15*100 + 0.1*70 + 0.1*70 + 0.25*75 + 0.2*80 ≈ 83",
    "practical_range": "实际综合分范围约30-95，不太可能出现极端值"
  }
}
